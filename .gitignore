# Ignore everything
*

# ── Root files ──────────────────
!.gitignore
!.github/
!.github/**
!scripts/
!scripts/setup-android-signing.cmd
!README.md
!README.zh-Hans.md
!index.html
!package.json
!pnpm-lock.yaml
!tsconfig.json
!tsconfig.node.json
!vite.config.ts
!README.md

# ── Source ──────────────────────
!src/
!src/**

# ── Public assets ───────────────
!public/
!public/**

# ── Docs ────────────────────────
!docs/
!docs/**

# ── Tauri ───────────────────────
!src-tauri/
!src-tauri/**

# Re-ignore Tauri build outputs
src-tauri/target/
src-tauri/gen/schemas/
